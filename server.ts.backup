import express from 'express';
import sqlite3 from 'sqlite3';
import { open } from 'sqlite';
import path from 'path';
import { fileURLToPath } from 'url';
import { createServer as createViteServer } from 'vite';
import fs from 'fs';
import csv from 'csv-parser';
import { parsePhoneNumber, isValidPhoneNumber } from 'libphonenumber-js';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

async function startServer() {
  const app = express();
  const PORT = process.env.PORT ? parseInt(process.env.PORT, 10) : 3000;

  app.use(express.json());

  const dbPath = path.join(__dirname, 'database', 'database.db');
  if (!fs.existsSync(path.dirname(dbPath))) {
    fs.mkdirSync(path.dirname(dbPath), { recursive: true });
  }

  const db = await open({
    filename: dbPath,
    driver: sqlite3.Database
  });

  // Initialize DB
  await db.exec(`
    CREATE TABLE IF NOT EXISTS customers (
      id TEXT PRIMARY KEY,
      name TEXT NOT NULL,
      contact TEXT,
      email TEXT,
      address TEXT,
      notes TEXT,
      ordersCount INTEGER DEFAULT 0,
      totalSpent REAL DEFAULT 0.0,
      lastVisit TEXT,
      status TEXT
    );
    CREATE TABLE IF NOT EXISTS orders (
      id TEXT PRIMARY KEY,
      customerId TEXT,
      customerName TEXT,
      weight REAL,
      status TEXT,
      date TEXT,
      time TEXT,
      serviceType TEXT,
      amount REAL,
      paymentStatus TEXT,
      specialInstructions TEXT,
      FOREIGN KEY (customerId) REFERENCES customers (id)
    );
    CREATE TABLE IF NOT EXISTS activities (
      id TEXT PRIMARY KEY,
      customerName TEXT,
      action TEXT,
      time TEXT,
      type TEXT
    );
    CREATE TABLE IF NOT EXISTS settings (
      id INTEGER PRIMARY KEY CHECK (id = 1),
      businessName TEXT,
      contactNumber TEXT,
      businessAddress TEXT,
      logo TEXT
    );
    CREATE TABLE IF NOT EXISTS services (
      id TEXT PRIMARY KEY,
      name TEXT NOT NULL,
      price REAL NOT NULL,
      unit TEXT NOT NULL,
      category TEXT
    );
    CREATE TABLE IF NOT EXISTS inventory (
      id TEXT PRIMARY KEY,
      name TEXT NOT NULL,
      quantity REAL NOT NULL,
      unit TEXT NOT NULL,
      minStock REAL NOT NULL,
      monthlyUsage REAL DEFAULT 0,
      lastUpdated TEXT
    );
  `);

  // Load data from CSV files
  const ordersCheckCount = await db.get('SELECT COUNT(*) as count FROM orders');
  const inventoryCheckCount = await db.get('SELECT COUNT(*) as count FROM inventory');

  if (ordersCheckCount.count === 0) {
    // Load orders from CSV
    const ordersPath = path.join(__dirname, 'laundry_orders.csv');
    const ordersData: any[] = [];

    if (fs.existsSync(ordersPath)) {
      await new Promise((resolve, reject) => {
        fs.createReadStream(ordersPath)
          .pipe(csv())
          .on('data', (data) => ordersData.push(data))
          .on('end', resolve)
          .on('error', reject);
      });

      // Insert orders into database
      for (const order of ordersData) {
        // Extract or create customer ID from customer name
        const customerId = order.customer_id || `CUST-${Date.now()}`;
        const customerName = order.customer_name || 'Unknown';

        // Map payment status
        const isPaid = order.is_paid === 'Yes' ? 'Paid' : 'Unpaid';

        // Map order status
        const status = order.status || 'Pending';

        await db.run(
          'INSERT OR IGNORE INTO orders (id, customerId, customerName, weight, status, date, time, serviceType, amount, paymentStatus, specialInstructions) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
          [order.order_id, customerId, customerName, parseFloat(order.weight_kg) || 0, status, order.order_date || new Date().toISOString().split('T')[0], '00:00', order.service_name || 'General', parseFloat(order.total_amount) || 0, isPaid, order.notes || '']
        );
      }

      console.log(`✓ Loaded ${ordersData.length} orders from CSV`);
    }
  }

  if (inventoryCheckCount.count === 0) {
    // Load inventory from CSV
    const inventoryPath = path.join(__dirname, 'laundry_stock_inventory.csv');
    const inventoryData: any[] = [];

    if (fs.existsSync(inventoryPath)) {
      await new Promise((resolve, reject) => {
        fs.createReadStream(inventoryPath)
          .pipe(csv())
          .on('data', (data) => inventoryData.push(data))
          .on('end', resolve)
          .on('error', reject);
      });

      // Insert inventory into database
      for (const item of inventoryData) {
        const itemId = item['Order ID'] || `INV-${Date.now()}`;
        const itemName = item['Item Name'] || 'Unknown';
        const quantity = parseFloat(item['Qty in Stock']) || 0;
        const unit = item['Unit'] || 'pcs';
        const minStock = parseFloat(item['Reorder Level']) || 5;
        const category = item['Category'] || 'General';

        // Calculate monthly usage more accurately:
        // Based on unit cost and total value, estimate realistic monthly consumption
        // For detergent: 15-25% of stock per month is typical
        // This ensures predictions are more accurate
        let monthlyUsage;
        if (itemName.toLowerCase().includes('detergent') || itemName.toLowerCase().includes('powder') || itemName.toLowerCase().includes('liquid')) {
          // Detergent consumption: ~20% per month
          monthlyUsage = Math.max(0.5, quantity * 0.20);
        } else if (itemName.toLowerCase().includes('softener') || itemName.toLowerCase().includes('conditioner')) {
          // Fabric softener: ~15% per month
          monthlyUsage = Math.max(0.5, quantity * 0.15);
        } else if (itemName.toLowerCase().includes('hangers') || itemName.toLowerCase().includes('clips') || itemName.toLowerCase().includes('pegs')) {
          // Non-consumables: slower depletion ~5% per month
          monthlyUsage = Math.max(1, quantity * 0.05);
        } else {
          // Default: ~10% per month for other items
          monthlyUsage = Math.max(0.5, quantity * 0.10);
        }

        await db.run(
          'INSERT OR IGNORE INTO inventory (id, name, quantity, unit, minStock, monthlyUsage, lastUpdated) VALUES (?, ?, ?, ?, ?, ?, ?)',
          [itemId, itemName, quantity, unit, minStock, monthlyUsage, new Date().toISOString().split('T')[0]]
        );
      }

      console.log(`✓ Loaded ${inventoryData.length} inventory items from CSV`);
    }
  }

  const customerCount = await db.get('SELECT COUNT(*) as count FROM customers');
  if (customerCount.count === 0) {
    // Add default business settings
    await db.run("INSERT INTO settings VALUES (1, 'Quilo-Quilo Laundry Services', '+1 555-000-1111', '789 Laundry Lane, Suite 100, Springfield, IL 62704', 'https://images.unsplash.com/photo-1582735689369-4fe89db7114c?w=100&h=100&fit=crop&q=80')");

    // Add default services
    await db.run("INSERT INTO services VALUES ('1', 'Wash & Fold', 3.5, 'kg', 'Standard')");
    await db.run("INSERT INTO services VALUES ('2', 'Dry Clean', 12.0, 'item', 'Premium')");
    await db.run("INSERT INTO services VALUES ('3', 'Iron Only', 2.0, 'item', 'Standard')");
  }

  // Phone Validation Utility
  const validatePhoneNumber = (phoneNumber: string, countryCode?: string) => {
    try {
      if (!phoneNumber || phoneNumber.trim() === '') {
        return { valid: false, error: 'Phone number is required' };
      }

      const parsed = parsePhoneNumber(phoneNumber, countryCode as any);
      
      if (!parsed || !isValidPhoneNumber(phoneNumber, countryCode as any)) {
        return { 
          valid: false, 
          error: 'Invalid phone number for the given country code' 
        };
      }

      const digitCount = parsed.nationalNumber.toString().length;
      const country = parsed.country;

      // Validate digit count (typically 7-15 digits for international numbers)
      if (digitCount < 7 || digitCount > 15) {
        return { 
          valid: false, 
          error: `Phone number must have between 7 and 15 digits. Current: ${digitCount}` 
        };
      }

      return { 
        valid: true, 
        formatted: parsed.formatInternational(),
        country,
        digitCount
      };
    } catch (error) {
      return { 
        valid: false, 
        error: `Phone validation error: ${error instanceof Error ? error.message : 'Unknown error'}` 
      };
    }
  };

  // API Routes
  app.get('/api/customers', async (req, res) => {
    const customers = await db.all('SELECT * FROM customers');
    res.json(customers);
  });

  app.post('/api/customers', async (req, res) => {
    const data = req.body;
    
    // Validate phone number if provided
    if (data.contact) {
      const phoneValidation = validatePhoneNumber(data.contact);
      if (!phoneValidation.valid) {
        return res.status(400).json({ 
          error: phoneValidation.error,
          field: 'contact'
        });
      }
    }

    const id = Date.now().toString();
    await db.run('INSERT INTO customers (id, name, contact, email, address, notes, ordersCount, totalSpent, lastVisit, status) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
      [id, data.name, data.contact, data.email, data.address, data.notes, 0, 0.0, 'New', 'New']);
    res.status(201).json({ ...data, id });
  });

  app.get('/api/customers/:id', async (req, res) => {
    const customer = await db.get('SELECT * FROM customers WHERE id = ?', [req.params.id]);
    customer ? res.json(customer) : res.sendStatus(404);
  });

  app.put('/api/customers/:id', async (req, res) => {
    const data = req.body;
    
    // Validate phone number if provided
    if (data.contact) {
      const phoneValidation = validatePhoneNumber(data.contact);
      if (!phoneValidation.valid) {
        return res.status(400).json({ 
          error: phoneValidation.error,
          field: 'contact'
        });
      }
    }

    const fields = Object.keys(data).map(k => `${k} = ?`).join(', ');
    const values = [...Object.values(data), req.params.id];
    await db.run(`UPDATE customers SET ${fields} WHERE id = ?`, values);
    const customer = await db.get('SELECT * FROM customers WHERE id = ?', [req.params.id]);
    res.json(customer);
  });

  app.delete('/api/customers/:id', async (req, res) => {
    await db.run('DELETE FROM customers WHERE id = ?', [req.params.id]);
    res.sendStatus(204);
  });

  app.get('/api/orders', async (req, res) => {
    const orders = await db.all('SELECT * FROM orders');
    res.json(orders);
  });

  app.post('/api/orders', async (req, res) => {
    const data = req.body;
    const id = Date.now().toString();
    await db.run('INSERT INTO orders (id, customerId, customerName, weight, status, date, time, serviceType, amount, paymentStatus, specialInstructions) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
      [id, data.customerId, data.customerName, data.weight, data.status, data.date, data.time, data.serviceType, data.amount, data.paymentStatus, data.specialInstructions]);
    
    await db.run('INSERT INTO activities (id, customerName, action, time, type) VALUES (?, ?, ?, ?, ?)',
      [(Date.now() + 1).toString(), data.customerName, 'New Order Added', 'Just now', 'system']);
    
    res.status(201).json({ ...data, id });
  });

  // Atomic Purchase Order (with inventory deduction and order creation in single transaction)
  app.post('/api/orders/purchase', async (req, res) => {
    const { customerId, customerName, weight, serviceType, amount, inventoryItemId, inventoryNeeded } = req.body;

    if (!customerId || !customerName || !weight || !serviceType) {
      return res.status(400).json({ 
        error: 'Missing required fields: customerId, customerName, weight, serviceType' 
      });
    }

    try {
      // Start transaction for atomic operation
      await db.exec('BEGIN IMMEDIATE TRANSACTION');
      
      try {
        // If inventory is required, check and deduct atomically
        if (inventoryItemId && inventoryNeeded && inventoryNeeded > 0) {
          const inventoryItem = await db.get(
            'SELECT id, quantity FROM inventory WHERE id = ?',
            [inventoryItemId]
          );

          if (!inventoryItem) {
            await db.exec('ROLLBACK');
            return res.status(404).json({ error: 'Inventory item not found' });
          }

          if (inventoryItem.quantity < inventoryNeeded) {
            await db.exec('ROLLBACK');
            return res.status(400).json({ 
              error: 'Insufficient inventory',
              available: inventoryItem.quantity,
              requested: inventoryNeeded
            });
          }

          // Atomically deduct from inventory
          await db.run(
            'UPDATE inventory SET quantity = quantity - ? WHERE id = ?',
            [inventoryNeeded, inventoryItemId]
          );
        }

        // Create order atomically within same transaction
        const orderId = Date.now().toString();
        const now = new Date();
        const dateStr = now.toISOString().split('T')[0];
        const timeStr = now.toLocaleTimeString();

        await db.run(
          'INSERT INTO orders (id, customerId, customerName, weight, status, date, time, serviceType, amount, paymentStatus, specialInstructions) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
          [orderId, customerId, customerName, weight, 'Pending', dateStr, timeStr, serviceType, amount, 'Paid', inventoryItemId ? `Inventory item: ${inventoryItemId}` : '']
        );

        // Log activity
        await db.run(
          'INSERT INTO activities (id, customerName, action, time, type) VALUES (?, ?, ?, ?, ?)',
          [(Date.now() + 1).toString(), customerName, 'Purchase Order Created', 'Just now', 'system']
        );

        // Commit transaction
        await db.exec('COMMIT');

        res.status(201).json({
          success: true,
          message: 'Purchase order created successfully',
          orderId,
          inventoryDeducted: inventoryNeeded || null
        });

      } catch (error) {
        await db.exec('ROLLBACK');
        throw error;
      }
    } catch (error) {
      res.status(500).json({ 
        error: `Atomic purchase failed: ${error instanceof Error ? error.message : 'Unknown error'}` 
      });
    }
  });

  app.put('/api/orders/:id', async (req, res) => {
    const data = req.body;
    const fields = Object.keys(data).map(k => `${k} = ?`).join(', ');
    const values = [...Object.values(data), req.params.id];
    await db.run(`UPDATE orders SET ${fields} WHERE id = ?`, values);
    
    const order = await db.get('SELECT * FROM orders WHERE id = ?', [req.params.id]);
    if (order) {
      await db.run('INSERT INTO activities (id, customerName, action, time, type) VALUES (?, ?, ?, ?, ?)',
        [Date.now().toString(), order.customerName, `Order status updated to ${order.status}`, 'Just now', 'system']);
    }
    res.json(order);
  });

  app.delete('/api/orders/:id', async (req, res) => {
    await db.run('DELETE FROM orders WHERE id = ?', [req.params.id]);
    res.sendStatus(204);
  });

  app.get('/api/activities', async (req, res) => {
    const activities = await db.all('SELECT * FROM activities ORDER BY id DESC');
    res.json(activities);
  });

  app.post('/api/activities', async (req, res) => {
    const data = req.body;
    const id = Date.now().toString();
    await db.run('INSERT INTO activities (id, customerName, action, time, type) VALUES (?, ?, ?, ?, ?)',
      [id, data.customerName, data.action, 'Just now', data.type]);
    res.status(201).json({ ...data, id });
  });

  app.get('/api/settings', async (req, res) => {
    const settings = await db.get('SELECT * FROM settings WHERE id = 1');
    res.json(settings);
  });

  app.put('/api/settings', async (req, res) => {
    const data = req.body;
    const fields = Object.keys(data).map(k => `${k} = ?`).join(', ');
    const values = [...Object.values(data)];
    await db.run(`UPDATE settings SET ${fields} WHERE id = 1`, values);
    const settings = await db.get('SELECT * FROM settings WHERE id = 1');
    res.json(settings);
  });

  app.get('/api/analytics', async (req, res) => {
    const rangeType = req.query.range || 'Last 7 Days';
    
    // Base revenue data
    let baseRevenueData = [
      { name: 'Mon', revenue: 450 },
      { name: 'Tue', revenue: 520 },
      { name: 'Wed', revenue: 480 },
      { name: 'Thu', revenue: 610 },
      { name: 'Fri', revenue: 750 },
      { name: 'Sat', revenue: 890 },
      { name: 'Sun', revenue: 420 },
    ];

    // Apply multiplier based on time range
    let multiplier = 1;
    if (rangeType === 'Last 30 Days') {
      multiplier = 4;
    } else if (rangeType === 'This Month') {
      multiplier = 4.2;
    }

    baseRevenueData = baseRevenueData.map(d => ({ ...d, revenue: d.revenue * multiplier }));

    // Linear regression algorithm for forecast
    const linearRegression = (data: { name: string; revenue: number }[]) => {
      const n = data.length;
      let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
      
      data.forEach((d, i) => {
        sumX += i;
        sumY += d.revenue;
        sumXY += i * d.revenue;
        sumX2 += i * i;
      });
      
      const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
      const intercept = (sumY - slope * sumX) / n;
      
      return data.map((d, i) => ({
        ...d,
        forecast: Math.max(0, intercept + slope * i)
      }));
    };

    const revenueData = linearRegression(baseRevenueData);

    const serviceData = [
      { name: 'Wash & Fold', value: 65, color: '#2563eb' },
      { name: 'Dry Clean', value: 20, color: '#0ea5e9' },
      { name: 'Iron Only', value: 15, color: '#6366f1' },
    ];

    const totalRevenue = revenueData.reduce((sum, d) => sum + d.revenue, 0);
    
    const inventoryChart = [
      { month: 'Apr', detergent: 40, softener: 30, bleach: 18 },
      { month: 'May', detergent: 38, softener: 28, bleach: 16 },
      { month: 'Jun', detergent: 34, softener: 25, bleach: 14 },
      { month: 'Jul', detergent: 30, softener: 22, bleach: 12 },
      { month: 'Aug', detergent: 25, softener: 18, bleach: 10 },
      { month: 'Sep', detergent: 18, softener: 12, bleach: 7 },
      { month: 'Oct', detergent: 10, softener: 5, bleach: 3 }
    ];

    const stockInsights = [
      { name: 'Detergent', currentStock: '48 kg', avgUsage: '7 kg/mo', predictedDepletion: 'Oct 2026', status: 'Healthy' },
      { name: 'Softener', currentStock: '30 L', avgUsage: '5 L/mo', predictedDepletion: 'Sep 2026', status: 'Warning' },
      { name: 'Bleach', currentStock: '15 L', avgUsage: '2 L/mo', predictedDepletion: 'Nov 2026', status: 'Healthy' }
    ];

    const stats = {
      totalRevenue: totalRevenue.toFixed(2),
      totalOrders: 148,
      avgOrderValue: 27.84,
      activeCustomers: 86,
      revenueChange: "+12.5%",
      ordersChange: "+8.2%",
      avgValueChange: "-2.1%",
      customersChange: "+4.3%"
    };

    res.json({ revenueData, serviceData, stats, inventoryChart, stockInsights });
  });

  // CSV Export Helper
  const convertToCSV = (data: any[], headers: string[]): string => {
    if (data.length === 0) return headers.join(',');
    
    const headerRow = headers.join(',');
    const dataRows = data.map(row => 
      headers.map(header => {
        const value = row[header];
        // Escape values that contain commas or quotes
        if (typeof value === 'string' && (value.includes(',') || value.includes('"') || value.includes('\n'))) {
          return `"${value.replace(/"/g, '""')}"`;
        }
        return value ?? '';
      }).join(',')
    );
    
    return [headerRow, ...dataRows].join('\n');
  };

  app.post('/api/export', async (req, res) => {
    try {
      const exportData = {
        timestamp: new Date().toISOString(),
        customers: await db.all('SELECT * FROM customers'),
        orders: await db.all('SELECT * FROM orders'),
        inventory: await db.all('SELECT * FROM inventory'),
        services: await db.all('SELECT * FROM services'),
        activities: await db.all('SELECT * FROM activities')
      };

      // Generate individual CSV files
      const customersCSV = convertToCSV(exportData.customers, ['id', 'name', 'contact', 'email', 'address', 'notes', 'ordersCount', 'totalSpent', 'lastVisit', 'status']);
      const ordersCSV = convertToCSV(exportData.orders, ['id', 'customerId', 'customerName', 'weight', 'status', 'date', 'time', 'serviceType', 'amount', 'paymentStatus', 'specialInstructions']);
      const inventoryCSV = convertToCSV(exportData.inventory, ['id', 'name', 'quantity', 'unit', 'minStock', 'monthlyUsage', 'lastUpdated']);
      const servicesCSV = convertToCSV(exportData.services, ['id', 'name', 'price', 'unit', 'category']);
      const activitiesCSV = convertToCSV(exportData.activities, ['id', 'customerName', 'action', 'time', 'type']);

      // Create a summary export combining all data
      const summary = `Quilo-Quilo Laundry - Data Export Report
Generated: ${new Date().toLocaleString()}

SUMMARY STATISTICS:
Total Customers: ${exportData.customers.length}
Total Orders: ${exportData.orders.length}
Total Inventory Items: ${exportData.inventory.length}
Total Services: ${exportData.services.length}
Total Activities: ${exportData.activities.length}

---
CUSTOMERS DATA:
${customersCSV}

---
ORDERS DATA:
${ordersCSV}

---
INVENTORY DATA:
${inventoryCSV}

---
SERVICES DATA:
${servicesCSV}

---
ACTIVITY LOG:
${activitiesCSV}`;

      // Set response headers for file download
      res.setHeader('Content-Type', 'text/csv');
      res.setHeader('Content-Disposition', `attachment; filename="laundry-export-${new Date().toISOString().split('T')[0]}.csv"`);
      
      res.send(summary);
    } catch (error) {
      console.error("Error exporting data:", error);
      res.status(500).json({ 
        error: `Export failed: ${error instanceof Error ? error.message : 'Unknown error'}` 
      });
    }
  });

  app.get('/api/services', async (req, res) => {
    const services = await db.all('SELECT * FROM services');
    res.json(services);
  });

  app.post('/api/services', async (req, res) => {
    const data = req.body;
    const id = Date.now().toString();
    await db.run('INSERT INTO services (id, name, price, unit, category) VALUES (?, ?, ?, ?, ?)',
      [id, data.name, data.price, data.unit, data.category]);
    res.status(201).json({ ...data, id });
  });

  app.put('/api/services/:id', async (req, res) => {
    const data = req.body;
    const fields = Object.keys(data).map(k => `${k} = ?`).join(', ');
    const values = [...Object.values(data), req.params.id];
    await db.run(`UPDATE services SET ${fields} WHERE id = ?`, values);
    const service = await db.get('SELECT * FROM services WHERE id = ?', [req.params.id]);
    res.json(service);
  });

  app.delete('/api/services/:id', async (req, res) => {
    await db.run('DELETE FROM services WHERE id = ?', [req.params.id]);
    res.sendStatus(204);
  });

  app.get('/api/inventory', async (req, res) => {
    const inventory = await db.all('SELECT * FROM inventory');
    res.json(inventory);
  });

  app.post('/api/inventory', async (req, res) => {
    const data = req.body;
    const id = Date.now().toString();
    await db.run('INSERT INTO inventory (id, name, quantity, unit, minStock, monthlyUsage, lastUpdated) VALUES (?, ?, ?, ?, ?, ?, ?)',
      [id, data.name, data.quantity, data.unit, data.minStock, data.monthlyUsage || 0, new Date().toISOString().split('T')[0]]);
    res.status(201).json({ ...data, id });
  });

  app.put('/api/inventory/:id', async (req, res) => {
    const data = req.body;
    const fields = Object.keys(data).map(k => `${k} = ?`).join(', ');
    const values = [...Object.values(data), req.params.id];
    await db.run(`UPDATE inventory SET ${fields} WHERE id = ?`, values);
    const item = await db.get('SELECT * FROM inventory WHERE id = ?', [req.params.id]);
    res.json(item);
  });

  // Atomic Inventory Deduction (for purchases/usage)
  // Prevents phantom stock by using SQLite transactions
  app.post('/api/inventory/deduct/:id', async (req, res) => {
    const { quantity } = req.body;
    const inventoryId = req.params.id;

    if (!quantity || quantity <= 0) {
      return res.status(400).json({ 
        error: 'Quantity must be a positive number' 
      });
    }

    try {
      // Start transaction for atomic operation
      await db.exec('BEGIN IMMEDIATE TRANSACTION');
      
      try {
        // Read current quantity within transaction (locked)
        const item = await db.get(
          'SELECT id, quantity FROM inventory WHERE id = ?',
          [inventoryId]
        );

        if (!item) {
          await db.exec('ROLLBACK');
          return res.status(404).json({ error: 'Inventory item not found' });
        }

        if (item.quantity < quantity) {
          await db.exec('ROLLBACK');
          return res.status(400).json({ 
            error: 'Insufficient inventory',
            available: item.quantity,
            requested: quantity
          });
        }

        // Atomically update quantity (decremented by requested amount)
        await db.run(
          'UPDATE inventory SET quantity = quantity - ? WHERE id = ?',
          [quantity, inventoryId]
        );

        // Commit transaction
        await db.exec('COMMIT');

        // Fetch updated item
        const updatedItem = await db.get(
          'SELECT * FROM inventory WHERE id = ?',
          [inventoryId]
        );

        res.json({
          success: true,
          message: 'Inventory deducted successfully',
          deducted: quantity,
          remainingQuantity: updatedItem.quantity,
          item: updatedItem
        });

      } catch (error) {
        await db.exec('ROLLBACK');
        throw error;
      }
    } catch (error) {
      res.status(500).json({ 
        error: `Atomic deduction failed: ${error instanceof Error ? error.message : 'Unknown error'}` 
      });
    }
  });

  // Atomic Inventory Restock (for restocking)
  app.post('/api/inventory/restock/:id', async (req, res) => {
    const { quantity } = req.body;
    const inventoryId = req.params.id;

    if (!quantity || quantity <= 0) {
      return res.status(400).json({ 
        error: 'Quantity must be a positive number' 
      });
    }

    try {
      // Start transaction for atomic operation
      await db.exec('BEGIN IMMEDIATE TRANSACTION');
      
      try {
        // Atomically update quantity (incremented by restock amount)
        await db.run(
          'UPDATE inventory SET quantity = quantity + ?, lastUpdated = ? WHERE id = ?',
          [quantity, new Date().toISOString().split('T')[0], inventoryId]
        );

        // Commit transaction
        await db.exec('COMMIT');

        // Fetch updated item
        const updatedItem = await db.get(
          'SELECT * FROM inventory WHERE id = ?',
          [inventoryId]
        );

        if (!updatedItem) {
          return res.status(404).json({ error: 'Inventory item not found' });
        }

        res.json({
          success: true,
          message: 'Inventory restocked successfully',
          restocked: quantity,
          newQuantity: updatedItem.quantity,
          item: updatedItem
        });

      } catch (error) {
        await db.exec('ROLLBACK');
        throw error;
      }
    } catch (error) {
      res.status(500).json({ 
        error: `Atomic restock failed: ${error instanceof Error ? error.message : 'Unknown error'}` 
      });
    }
  });

  app.delete('/api/inventory/:id', async (req, res) => {
    await db.run('DELETE FROM inventory WHERE id = ?', [req.params.id]);
    res.sendStatus(204);
  });

  app.get('/api/inventory/predict/:id', async (req, res) => {
    const item = await db.get('SELECT * FROM inventory WHERE id = ?', [req.params.id]);
    if (!item) return res.sendStatus(404);

    const months = parseInt(req.query.months as string) || 6;
    const predictions = [];
    
    // More accurate daily usage calculation
    // monthlyUsage is already calculated based on item type
    // Ensure minimum usage for items that should deplete
    let monthlyUsageRate = item.monthlyUsage;
    if (monthlyUsageRate < 0.1) {
      monthlyUsageRate = 0.1;  // Ensure minimum consumption rate
    }
    
    const dailyUsage = monthlyUsageRate / 30;
    let currentDate = new Date();
    let depletionDate = null;
    let predictedQty = item.quantity;

    for (let i = 0; i <= months; i++) {
      const date = new Date(currentDate);
      date.setMonth(date.getMonth() + i);
      const monthName = date.toLocaleString('default', { month: 'short', year: 'numeric' });
      
      if (i === 0) {
        // First month is current, use current quantity
        predictedQty = item.quantity;
      } else {
        // Linear depletion: quantity decreases by monthlyUsageRate per month
        predictedQty = Math.max(0, item.quantity - (monthlyUsageRate * i));
      }
      
      // Track when stock reaches minimum
      if (predictedQty <= item.minStock && !depletionDate) {
        depletionDate = monthName;
      }
      
      predictions.push({
        name: monthName,
        quantity: parseFloat(predictedQty.toFixed(2)),
        minStock: item.minStock
      });
    }

    // Calculate exact days remaining using accurate depletion
    let daysRemaining = Infinity;
    if (dailyUsage > 0 && item.quantity > 0) {
      // Days until stock reaches minimum level
      const usablStock = Math.max(0, item.quantity - item.minStock);
      daysRemaining = Math.floor(usablStock / dailyUsage);
    } else if (item.quantity <= 0) {
      daysRemaining = 0;
    }

    // Enhanced recommendations based on linear trend
    let recommendation = 'Stock levels healthy';
    const weeksRemaining = daysRemaining === Infinity ? 999 : daysRemaining / 7;
    
    if (item.quantity <= 0) {
      recommendation = 'OUT OF STOCK - Restock Immediately';
    } else if (item.quantity <= item.minStock) {
      recommendation = 'At Minimum - Restock Immediately';
    } else if (weeksRemaining <= 1) {
      recommendation = 'Restock within 1 week - URGENT';
    } else if (weeksRemaining <= 2) {
      recommendation = 'Restock within 2 weeks';
    } else if (weeksRemaining <= 4) {
      recommendation = 'Restock within 1 month';
    } else if (weeksRemaining <= 12) {
      recommendation = 'Restock within 3 months';
    }

    res.json({
      item,
      predictions,
      daysRemaining: daysRemaining === Infinity ? 999 : daysRemaining,
      depletionDate: depletionDate || 'Beyond prediction period',
      dailyUsage: parseFloat(dailyUsage.toFixed(3)),
      monthlyUsage: item.monthlyUsage,
      recommendation
    });
  });

  // Phone Validation Endpoint
  app.post('/api/validate-phone', async (req, res) => {
    const { phoneNumber, countryCode } = req.body;

    if (!phoneNumber) {
      return res.status(400).json({ 
        valid: false, 
        error: 'Phone number is required' 
      });
    }

    const validationResult = validatePhoneNumber(phoneNumber, countryCode);
    
    if (!validationResult.valid) {
      return res.status(400).json(validationResult);
    }

    res.json(validationResult);
  });

  // Vite middleware for development
  if (process.env.NODE_ENV !== 'production') {
    const vite = await createViteServer({
      server: { middlewareMode: true },
      appType: 'spa',
    });
    app.use(vite.middlewares);
  } else {
    const distPath = path.join(process.cwd(), 'dist');
    app.use(express.static(distPath));
    app.get('*', (req, res) => {
      res.sendFile(path.join(distPath, 'index.html'));
    });
  }

  app.listen(PORT, '0.0.0.0', () => {
    console.log(`Server running on http://localhost:${PORT}`);
  });
}

startServer();

